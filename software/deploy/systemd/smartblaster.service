[Unit]
Description=SmartBlaster Device Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/opt/smartblaster/software
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=/etc/smartblaster.env
ExecStart=$CODE_ROOT/.venv/bin/python3 $CODE_ROOT/src/smartblaster/main.py --mode auto --state-file /var/lib/smartblaster/device_setup.json --setup-host 0.0.0.0 --setup-port 8080 --enable-ap-mode --ap-use-sudo --ap-start-script $CODE_ROOT/deploy/ap/start_ap_mode.sh --ap-stop-script $CODE_ROOT/deploy/ap/stop_ap_mode.sh
Restart=always
RestartSec=3

# Hardening (relax if specific hardware access requires changes)
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/var/lib/smartblaster /var/log/smartblaster

[Install]
WantedBy=multi-user.target
